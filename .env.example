# 이 파일을 복사해 .env로 저장하고 실제 값을 채워 넣으세요.
# .env는 .gitignore에 이미 등록되어 있어 커밋되지 않습니다.

# 필수 — RAG 답변 생성(Part 5-1)에 사용하는 Anthropic Claude API 키.
# https://console.anthropic.com 에서 발급받으세요.
ANTHROPIC_API_KEY=sk-ant-...

# 선택 — 생성 모델을 바꾸고 싶을 때만 설정 (기본값: claude-haiku-4-5-20251001)
# RAG_LLM_MODEL=claude-haiku-4-5-20251001

# 선택 — LangSmith 모니터링(Part 6-2). 둘 다 비워두면 tracing 없이 정상 동작합니다.
# LANGCHAIN_API_KEY=lsv2_...
# LANGSMITH_API_KEY=lsv2_...
